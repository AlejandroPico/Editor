{
  "name": "atlas-editor",
  "private": true,
  "version": "0.7.0",
  "type": "module",
  "description": "Editor vectorial portable para esquemas, mapas e infografías interactivas.",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "build:web": "vite build",
    "build:offline": "vite build --mode offline --outDir dist-offline",
    "package": "node scripts/package-offline.mjs",
    "build": "npm run build:web && npm run build:offline && npm run package",
    "validate": "npm run check && npm run test && npm run build"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sql.js": "^1.14.1",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.10",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.5",
    "vite-plugin-singlefile": "^2.3.0",
    "vitest": "^4.1.10"
  }
}
